<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Browser">
            <directory>tests/Browser</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="GLOBAL_RANKING_VARIANT" value="sum"/>
        <env name="GLOBAL_RANKING_AVERAGE_CONFIDENCE_MAPS" value="2"/>
        <!-- .env has this on for the live redesign environment; tests need it off by default
             so submission_id stays optional except where a test explicitly opts in via
             config(['webhook.hrl_query.enforce' => true]). Without this override, tests here
             silently inherit .env's real value instead of an isolated test default. -->
        <env name="WEBHOOK_HRL_VERIFY_ENFORCE" value="false"/>
        <!-- Generous by default so unrelated tests submitting a few laps back-to-back never
             trip the webhook's real per-second burst limit; tests of the rate limiter itself
             override these low via config() at runtime. See config/webhook.php. -->
        <env name="WEBHOOK_RATE_LIMIT_UNVERIFIED_BURST" value="1000"/>
        <env name="WEBHOOK_RATE_LIMIT_VERIFIED_BURST" value="1000"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
